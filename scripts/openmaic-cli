#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
HARNESS_DIR="$REPO_DIR/agent-harness"
VENV_DIR="$HARNESS_DIR/.venv"
CLI="$VENV_DIR/bin/cli-anything-openmaic"

if [[ ! -x "$CLI" ]]; then
  echo "cli-anything-openmaic is not installed yet for this OpenMAIC checkout." >&2
  echo "Run:" >&2
  echo "  cd "$HARNESS_DIR" && python3 -m venv .venv && . .venv/bin/activate && python -m pip install -U pip && python -m pip install -e . pytest" >&2
  exit 1
fi

exec "$CLI" --repo "$REPO_DIR" "$@"
